---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { works } from '../data/works';

const directions = (await getCollection('directions')).sort((a, b) => a.data.order - b.data.order);
const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.planted.getTime() - a.data.planted.getTime() || a.data.order - b.data.order,
);

const essays = posts.filter((post) => post.data.type === 'essay');
const notes = posts.filter((post) => post.data.type !== 'essay');
const featuredWorks = works.slice(0, 4);

const stageLabel: Record<string, string> = {
  seed: '种子',
  budding: '生长中',
  evergreen: '常青',
};

const stageIcon: Record<string, string> = {
  seed: '✦',
  budding: '❧',
  evergreen: '✺',
};

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'short' }).format(date);
---

<Base
  title="Sebastian Lim — AI 系统、学习与公开实验"
  description="Sebastian Lim 的个人花园与工作室：受约束 AI、学习系统、归档实验，以及沿路形成的文章、笔记和作品。"
  current="home"
  root="."
>
  <header class="home-intro">
    <p class="eyebrow">个人花园与工作室</p>
    <h1><strong>Sebastian</strong> 构建有边界、可验证的 AI 系统，并记录它们如何帮助人学习、整理知识和完成真实工作。</h1>
    <p class="intro-subtitle">独立开发者。当前主要探索受约束 AI 与 AI 学习系统，也长期关心归档、本地优先和作品背后的个人品味。</p>
  </header>

  <section class="garden-heading" aria-labelledby="garden-title">
    <div>
      <p class="eyebrow">The Garden</p>
      <h2 id="garden-title">正在生长的内容</h2>
    </div>
    <p>这里同时放完整文章、尚未想明白的笔记、长期方向和真实项目。不同成熟度的内容会被明确标记，而不是伪装成最终答案。</p>
  </section>

  <div class="garden-grid">
    <section class="garden-panel essays-panel" id="essays">
      <div class="section-heading">
        <div>
          <h3>文章</h3>
          <p>有明确观点和叙事目标的完整内容。</p>
        </div>
        <a href="#essays" aria-label="查看文章">→</a>
      </div>

      <div class="essay-grid">
        {essays.slice(0, 4).map((post, index) => (
          <a class:list={['essay-card', index === 0 && 'essay-card-featured']} href={`./posts/${post.id}.html`}>
            <div class="essay-visual" aria-hidden="true">
              <span>{post.data.topics[0] ?? 'Essay'}</span>
              <span class="visual-mark">{index % 2 === 0 ? '◇' : '○'}</span>
            </div>
            <div class="card-copy">
              <h4>{post.data.listTitle ?? post.data.title}</h4>
              <p>{post.data.summary}</p>
              <div class="card-meta">
                <span>{stageIcon[post.data.stage]} {stageLabel[post.data.stage]}</span>
                <span>{formatDate(post.data.tended ?? post.data.planted)}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="garden-panel notes-panel" id="notes">
      <div class="section-heading">
        <div>
          <h3>笔记与碎片</h3>
          <p>仍在理解、验证或等待连接的东西。</p>
        </div>
      </div>

      <div class="note-list">
        {(notes.length ? notes : essays).slice(0, 7).map((post) => (
          <a href={`./posts/${post.id}.html`}>
            <span class="growth-mark" aria-hidden="true">{stageIcon[post.data.stage]}</span>
            <span>
              <strong>{post.data.listTitle ?? post.data.title}</strong>
              <small>{post.data.type === 'essay' ? '待拆成笔记' : post.data.type} · {stageLabel[post.data.stage]}</small>
            </span>
          </a>
        ))}
      </div>
    </section>

    <section class="garden-panel directions-panel" id="directions">
      <div class="section-heading">
        <div>
          <h3>长期方向</h3>
          <p>不是一次性项目，而是我反复回到的问题。</p>
        </div>
      </div>

      <div class="direction-grid">
        {directions.map((direction) => (
          direction.data.page ? (
            <a class="direction-card" href={`./directions/${direction.id}.html`}>
              <span class="direction-number">0{direction.data.order}</span>
              <h4>{direction.data.title}</h4>
              <p>{direction.data.summary}</p>
              <span class="card-link">进入方向 →</span>
            </a>
          ) : (
            <article class="direction-card direction-card-muted">
              <span class="direction-number">0{direction.data.order}</span>
              <h4>{direction.data.title}</h4>
              <p>{direction.data.summary}</p>
              <span class="card-link">仍在筹备</span>
            </article>
          )
        ))}
      </div>
    </section>

    <section class="garden-panel work-panel" id="work">
      <div class="section-heading">
        <div>
          <h3>作品与实验</h3>
          <p>方向向前推进时留下的工具、案例和未完成探索。</p>
        </div>
      </div>

      <div class="work-grid">
        {featuredWorks.map((work) => (
          <article class="work-card">
            <div class="work-stage">{stageIcon[work.stage]} {stageLabel[work.stage]}</div>
            <h4>
              {work.nameLink ? (
                <a href={work.nameLink} target="_blank" rel="noopener noreferrer">{work.name}</a>
              ) : work.name}
            </h4>
            <p set:html={work.desc} />
            <div class="work-status" set:html={work.status} />
          </article>
        ))}
      </div>
    </section>
  </div>

  <section class="now-section" id="now">
    <div>
      <p class="eyebrow">Now · 2026 年 7 月</p>
      <h2>目前正在推进</h2>
    </div>
    <div class="now-grid">
      <article>
        <span>01</span>
        <h3>约束 AI</h3>
        <p>把模型放进可检查、可回退、有发布门槛的系统，而不是让它直接操作真实数据。</p>
      </article>
      <article>
        <span>02</span>
        <h3>学习系统</h3>
        <p>继续验证如何把教材、书籍和长期目标转换成真正能推进学习的产品体验。</p>
      </article>
      <article>
        <span>03</span>
        <h3>公开基地</h3>
        <p>让这个网站逐渐成为文章、案例、方向和个人品味之间的共同入口。</p>
      </article>
    </div>
  </section>

  <section class="contact-section">
    <p class="eyebrow">Keep in touch</p>
    <h2>对受约束 AI、学习产品或内容归档感兴趣？</h2>
    <p>可以从文章和项目开始，也可以直接写信交流。</p>
    <div class="contact-links">
      <a href="mailto:microseyuyu@gmail.com">发送邮件</a>
      <a href="https://github.com/Sebastianhayashi" target="_blank" rel="noopener noreferrer">查看 GitHub</a>
    </div>
  </section>
</Base>
